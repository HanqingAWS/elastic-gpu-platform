# NLP-Platform 节点运行时配置。bake-ami.sh 会据此写入 /etc/nlp/model.env,
# 供 nlp-fetch-model.sh / vllm.service / nlp-metrics-push.py 读取。
# 复制为 model.env 并按需修改(至少改 MODEL_BUCKET),再跑 bake-ami.sh。

# ---- 模型来源:单一 S3 桶(所有区节点都从这里拉;远区为跨区下载)----
MODEL_BUCKET=nlp-models-044324713311-us-east-1   # 单桶名(变量;不再逐区 nlp-models-*-<region>)
MODEL_BUCKET_REGION=us-east-1                     # 桶所在区(s5cmd 走此 endpoint)
MODEL_PREFIX=gemma-4-26B-A4B-it                   # 桶内模型前缀:s3://$MODEL_BUCKET/$MODEL_PREFIX/*

# ---- 推理引擎(vLLM;按你的机型/模型调 DP/TP)----
SERVING_PORT=8000                                 # 必须与环境配置向导里的"服务端口"一致
DP=4                                              # data-parallel(p4d/p4de = 8 卡 → DP4×TP2)
TP=2                                              # tensor-parallel
VLLM_IMAGE=vllm/vllm-openai:latest

# ---- 指标上报表(控制面 DynamoDB;跨区写)----
METRICS_TABLE=nlp-dev-metrics-rollup
METRICS_TABLE_REGION=us-east-1
