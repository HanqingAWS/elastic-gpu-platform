{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "types": ["node"]
  },
  "include": ["bin/**/*.ts", "lib/**/*.ts", "config/**/*.ts"],
  "exclude": ["node_modules", "cdk.out"]
}
